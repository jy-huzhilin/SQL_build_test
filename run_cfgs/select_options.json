    },
    {
      "_comment": "qualify 结构化字典（窗口函数 LHS）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
