        "func": "row_number",
        "window": {
          "partition_by": ["ths_code"],
          "order_by": [{"column": "date", "direction": "DESC"}]
        },
        "op": "=",
        "value": 1
      }
    },
    {
      "_comment": "qualify 列表格式（AND 连接窗口函数条件 + 普通列条件）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
