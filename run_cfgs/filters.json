{
  "input": [
    {
      "_comment": "字符串兜底条件",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": ["issue_credit_rating = 'AAA' AND ths_code LIKE '11%'"]
    },
    {
      "_comment": "结构化字典：= 运算符",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "issue_credit_rating", "op": "=", "value": "'AAA'"}]
    },
    {
      "_comment": "结构化字典：> 运算符",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [{"column": "close", "op": ">", "value": 100}]
    },
    {
      "_comment": "结构化字典：>= 运算符",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [{"column": "close", "op": ">=", "value": 100}]
    },
    {
      "_comment": "结构化字典：< 运算符",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [{"column": "close", "op": "<", "value": 150}]
    },
    {
      "_comment": "结构化字典：<= 运算符",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [{"column": "close", "op": "<=", "value": 150}]
    },
    {
      "_comment": "结构化字典：LIKE 运算符",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "ths_code", "op": "LIKE", "value": "11%"}]
    },
    {
      "_comment": "结构化字典：IN（列表）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "ths_code", "op": "IN", "value": ["110001.SH", "110002.SH", "110003.SH"]}]
    },
    {
      "_comment": "结构化字典：NOT IN（列表）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "issue_credit_rating", "op": "NOT IN", "value": ["AA-", "A+"]}]
    },
    {
      "_comment": "结构化字典：BETWEEN",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [{"column": "close", "op": "BETWEEN", "value": [50, 200]}]
    },
    {
      "_comment": "列表格式（OR 连接）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [
        [
          {"column": "close", "op": ">", "value": 200},
          {"column": "close", "op": "<", "value": 50}
        ]
      ]
    },
    {
      "_comment": "AND + IN + OR 列表混合",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [
        {"column": "ths_code", "op": "IN", "value": ["110001.SH", "110002.SH"]},
        {"column": "close", "op": ">", "value": 100},
        [
          {"column": "volume", "op": ">", "value": 10000},
          {"column": "pe",     "op": "<", "value": 30}
        ]
      ]
    },
    {
      "_comment": "column 为表达式 dict：toDate(time) = date",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_hf_1min_market"],
      "start_time": "-7200",
      "end_time": "schedule_now",
      "filters": [
        {"column": {"func": "toDate", "column": "time"}, "op": "=", "value": "toDate(now())"},
        {"column": "close", "op": ">", "value": 0}
      ]
    },
    {
      "_comment": "多列元组 IN：(ths_code, date) IN (...)",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_daily_quote_market"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [
        {"column": ["ths_code", "date"], "op": "IN", "value": [["110001.SH", "2026-03-03"], ["110002.SH", "2026-03-03"]]}
      ]
    },
    {
      "_comment": "多条件 AND：函数列 + 普通列",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_daily_quote_market"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [
        {"column": "ths_code", "op": "IN", "value": ["110001.SH", "110002.SH"]},
        {"column": "close", "op": ">", "value": 0},
        {"column": "volume", "op": ">", "value": 0}
      ]
    },
    {
      "_comment": "M5回归：= 运算符，字符串 value 不手动加引号（修复前会生成 col = AAA，修复后生成 col = 'AAA'）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "issue_credit_rating", "op": "=", "value": "AAA"}]
    },
    {
      "_comment": "M5回归：> 运算符，日期字符串 value（修复前生成 col > 2030-01-01，修复后生成 col > '2030-01-01'）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "maturity_date", "op": ">", "value": "2030-01-01"}]
    },
    {
      "_comment": "M5回归：LIKE 运算符，value 含单引号需转义（修复前生成 LIKE 'O'Brien%' 会报 SQL 错误）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "issue_credit_rating", "op": "LIKE", "value": "AA'%"}]
    },
    {
      "_comment": "M5回归：IN 运算符，list 中的值含单引号需转义（修复前生成 IN ('AA'+') 会报 SQL 错误）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "issue_credit_rating", "op": "IN", "value": ["AA+", "AA-", "AA'"]}]
    },
    {
      "_comment": "M6回归：= 运算符，value 为 SQL 函数表达式（修复前生成 col = 'toDate(now())'，修复后生成 col = toDate(now())）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_hf_1min_market"],
      "start_time": "-7200",
      "end_time": "schedule_now",
      "filters": [
        {"column": {"func": "toDate", "column": "time"}, "op": "=", "value": "toDate(now())"},
        {"column": "close", "op": ">", "value": 0}
      ]
    },
    {
      "_comment": "M6回归：= 运算符，value 已手动加单引号（修复前双重加引号变成 ''000001.SH''，修复后规范化为 '000001.SH'）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "ths_code", "op": "=", "value": "'110001.SH'"}]
    },
    {
      "_comment": "M6回归：IN 运算符，list 中的元素已手动加单引号（修复前双重加引号，修复后规范化）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "ths_code", "op": "IN", "value": ["'110001.SH'", "'110002.SH'"]}]
    },
    {
      "_comment": "M6回归：BETWEEN 两端为日期字符串（修复前生成 BETWEEN 2020-01-01 AND 2026-12-31 被当算术，修复后加引号）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.cbond_basic_info"],
      "filters": [{"column": "listed_date", "op": "BETWEEN", "value": ["2020-01-01", "2026-12-31"]}]
    },
    {
      "_comment": "M6回归：BETWEEN 两端为数字（不受影响，验证修复后数字不被错误加引号）",
      "type": "data",
      "db": "basic_data_db",
      "sources": ["cbond.stock_daily_quotes_non_ror"],
      "start_time": "-604800",
      "end_time": "schedule_now",
      "filters": [{"column": "close", "op": "BETWEEN", "value": [50, 200]}]
    }
  ],
  "output": [],
  "computation": {
    "external_source": "sql_test.py",
    "class_name": "SqlTest",
    "single": "compute",
    "batch": ""
  },
  "schedule": ["****-**-** 15:30:00"]
}
